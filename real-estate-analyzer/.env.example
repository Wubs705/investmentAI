# AI Analysis (required for AI features, app works without it)
ANTHROPIC_API_KEY=

# Property data APIs — app falls back to demo data without these
RENTCAST_API_KEY=
ESTATED_API_KEY=

# Market data (optional)
CENSUS_API_KEY=
# BLS API key (free) — register at https://data.bls.gov/registrationEngine/
# Without this, BLS requests are rate-limited to 25/day (usually enough for dev)
BLS_API_KEY=

# Legacy API key auth (used when Supabase is NOT configured)
API_AUTH_KEY=
AUTH_REQUIRED=false

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Mapbox (frontend) — get a free public token at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# App config
CACHE_DIR=./cache
CACHE_TTL_HOURS=24
MAX_RESULTS=20
DEFAULT_RADIUS_MILES=15
DEFAULT_DOWN_PAYMENT_PCT=20
