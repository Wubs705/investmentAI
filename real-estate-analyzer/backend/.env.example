# Copy to .env and fill in your values.
# Never commit .env to source control.

# Rentcast property listings API
RENTCAST_API_KEY=

# Estated property data API
ESTATED_API_KEY=

# HUD Fair Market Rents API
HUD_API_KEY=

# Anthropic AI API
ANTHROPIC_API_KEY=

# SQLite (dev) or Postgres connection string (prod via Supabase)
DATABASE_URL=sqlite+aiosqlite:///./real_estate.db

# Supabase (optional — required for auth & prod database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
