# Copy to .env.local and fill in your values.
# Never commit .env.local to source control.

# Base URL for the FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8000

# Location autocomplete is powered by Photon (https://photon.komoot.io) —
# zero config, no API key, no sign-up required.

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
# Leave blank to run the app without authentication (open/dev mode)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
